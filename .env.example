# ==========================================
# PocketCloud Environment Configuration
# ==========================================
# Copy this file to .env before starting the server:
#   cp .env.example .env

# Server Port (Default: 8080 as requested)
PORT=8080

# Security: Bcrypt or Argon2 password hash for admin login.
# Run `node scripts/hash-password.js your_secure_password` to generate your hash and paste it below.
# Default below is the bcrypt hash for "admin123" (CHANGE THIS IMMEDIATELY BEFORE EXPOSING TO NGROK!)
ADMIN_PASSWORD_HASH=$2a$10$X7uB9q2P2S2oW0h5Z3k8uOQ.L9F4Q5Z3k8uOQ.L9F4Q5Z3k8uOQ.L9

# Secret key used to sign JWT authentication tokens (generate a long random string!)
JWT_SECRET=super_secret_pocketcloud_jwt_key_change_me_in_production

# Storage Root Directory where files will be stored.
# In Termux on Android, this can point to `./uploads` or an external SD card symlink.
# Examples:
#   STORAGE_ROOT=./uploads
#   STORAGE_ROOT=/sdcard/PocketCloud
#   STORAGE_ROOT=/storage/emulated/0/PocketCloud
STORAGE_ROOT=./uploads

# Ngrok Authtoken (get yours for free at https://dashboard.ngrok.com/get-started/your-authtoken)
NGROK_AUTHTOKEN=your_ngrok_auth_token_here

# Rate Limiting (Prevent Brute-Force Login Attacks)
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes in milliseconds
RATE_LIMIT_MAX_ATTEMPTS=5   # Lock out after 5 failed attempts per IP
